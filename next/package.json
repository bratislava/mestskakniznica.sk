{
  "name": "city-library-next",
  "version": "0.1.0",
  "private": true,
  "license": "EUPL-1.2",
  "scripts": {
    "dev": "next dev",
    "develop": "npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint components pages utils hooks",
    "lint:fix": "npm run lint -- --fix",
    "lint:quiet": "npm run lint -- --quiet",
    "prettier": "prettier --write .",
    "gen": "graphql-codegen && prettier --write services/graphql/index.ts",
    "parse-translations": "i18next-cli extract",
    "update-react-aria": "npm install @internationalized/date@latest @react-stately/utils@latest react-aria@latest react-aria-components@latest react-stately@latest @react-aria/utils@latest tailwindcss-react-aria-components --save-exact",
    "update-markdown": "npm install react-markdown@latest --save-exact",
    "update-next": "npm install next@latest react@latest react-dom@latest sharp@latest --save-exact && npm install @types/react@latest @types/react-dom@latest typescript@latest @next/bundle-analyzer --save-dev --save-exact",
    "update-tailwind": "npm install tailwind-merge@latest clsx@latest --save-exact && npm install tailwindcss@latest postcss@latest prettier-plugin-tailwindcss@latest --save-dev --save-exact",
    "update-i18next": "npm install next-i18next@latest react-i18next@latest i18next@latest --save-exact && npm install i18next-cli@latest --save-dev --save-exact",
    "update-prettier": "npm install prettier@latest eslint-config-prettier@latest --save-dev --save-exact",
    "update-radix": "npm install @radix-ui/react-navigation-menu@latest --save-exact",
    "update-graphql": "npm install @graphql-codegen/cli@latest @graphql-codegen/typescript@latest @graphql-codegen/typescript-graphql-request@latest @graphql-codegen/typescript-operations@latest --save-dev --save-exact && npm install graphql@latest graphql-request@latest graphql-tag@latest --save-exact",
    "update-mapbox": "npm install react-map-gl@latest mapbox-gl@latest --save-exact"
  },
  "dependencies": {
    "@hookform/resolvers": "3.10.0",
    "@internationalized/date": "3.7.0",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@react-aria/utils": "3.27.0",
    "@react-stately/utils": "3.10.5",
    "@tanstack/react-query": "5.90.16",
    "axios": "1.16.1",
    "clsx": "2.1.1",
    "date-fns": "2.30.0",
    "focus-trap-react": "11.0.6",
    "framer-motion": "12.25.0",
    "googleapis": "102.0.0",
    "graphql": "16.10.0",
    "graphql-request": "6.1.0",
    "graphql-tag": "2.12.6",
    "i18next": "24.2.2",
    "lodash": "4.17.23",
    "mailgun-js": "0.22.0",
    "many-keys-map": "2.0.1",
    "mapbox-gl": "3.9.4",
    "meilisearch": "0.30.0",
    "next": "16.2.7",
    "next-i18next": "15.4.2",
    "next-plausible": "3.12.5",
    "nuqs": "2.8.9",
    "pretty-bytes": "6.1.1",
    "react": "19.2.7",
    "react-aria": "3.37.0",
    "react-aria-components": "1.6.0",
    "react-datepicker": "7.6.0",
    "react-dom": "19.2.7",
    "react-hook-form": "7.71.0",
    "react-i18next": "15.4.0",
    "react-map-gl": "7.1.9",
    "react-markdown": "9.0.3",
    "react-resize-detector": "12.0.2",
    "react-stately": "3.35.0",
    "react-turnstile": "1.1.4",
    "sharp": "0.35.0",
    "tailwind-merge": "3.6.0",
    "tailwind-scrollbar-hide": "4.0.0",
    "tailwindcss-radix": "4.0.2",
    "tailwindcss-react-aria-components": "2.0.0",
    "usehooks-ts": "3.1.1",
    "xml-js": "1.6.11",
    "yup": "0.32.11"
  },
  "devDependencies": {
    "@bratislava/eslint-config-next": "0.14.0",
    "@graphql-codegen/cli": "5.0.4",
    "@graphql-codegen/typescript": "4.1.3",
    "@graphql-codegen/typescript-graphql-request": "6.2.0",
    "@graphql-codegen/typescript-operations": "4.4.1",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/lodash": "4.17.23",
    "@types/mailgun-js": "0.22.19",
    "@types/node": "24.13.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-map-gl": "6.1.7",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.2",
    "i18next-cli": "1.61.0",
    "postcss": "8.5.8",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=24.16.x",
    "npm": ">=10.8.x"
  },
  "volta": {
    "node": "24.16.0",
    "npm": "10.8.2"
  }
}
